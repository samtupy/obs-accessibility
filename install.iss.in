#define PluginName "@CMAKE_PROJECT_NAME@"
#define PluginVersion "@CMAKE_PROJECT_VERSION@"
#define PluginPublisher "@PLUGIN_AUTHOR@"
#define PluginURL "@PLUGIN_WEBSITE@"

[Setup]
AppId={{3F9C2A8B-5E4D-4A6C-9B1E-D7F3A2C4B5E0}
AppName={#PluginName}
AppVersion={#PluginVersion}
AppPublisher={#PluginPublisher}
AppPublisherURL={#PluginURL}
AppSupportURL={#PluginURL}
AppUpdatesURL={#PluginURL}
DefaultDirName={commonappdata}\obs-studio\plugins\{#PluginName}
OutputBaseFilename={#PluginName}-{#PluginVersion}
Compression=lzma
SolidCompression=yes
DirExistsWarning=no

[Languages]
Name: "english"; MessagesFile: "compiler:Default.isl"

[Files]
Source: "{#PluginName}\*"; DestDir: "{app}"; Flags: ignoreversion recursesubdirs createallsubdirs
